Bootstrap: docker
From: ghcr.io/anikamehrotra/chatdbgpro-gdb-yara:latest

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive
    # Apptainer rootless --fakeroot puts us in a user namespace where apt
    # can't drop to the _apt user. Force apt to stay as root for sandboxing.
    echo 'APT::Sandbox::User "root";' > /etc/apt/apt.conf.d/00sandbox-user
    apt-get update
    apt-get install -y --no-install-recommends strace
    rm -rf /var/lib/apt/lists/*
    strace --version | head -1

%labels
    derived-from ghcr.io/anikamehrotra/chatdbgpro-gdb-yara:latest
    adds strace
    purpose probe + gdb on adroit (rootless apptainer)
