    The crash is caused by undefined behavior in this expression:               
                                                                                
                                                                                
     return (unsigned long long)(1 << width);                                   
                                                                                
                                                                                
    with:                                                                       
                                                                                
                                                                                
     width == 64                                                                
                                                                                
                                                                                
    Program state walkthrough                                                   
                                                                                
    In main:                                                                    
                                                                                
                                                                                
     int width = 64;                                                            
     unsigned long long m = high_bit_mask(width);                               
                                                                                
                                                                                
    So width is initialized to 64 and passed directly into high_bit_mask.       
                                                                                
    Inside high_bit_mask:                                                       
                                                                                
                                                                                
     static unsigned long long high_bit_mask(int width)                         
     {                                                                          
         return (unsigned long long)(1 << width);                               
     }                                                                          
                                                                                
                                                                                
    The important detail is that the left operand of the shift is the literal   
    1.                                                                          
                                                                                
    In C, the literal 1 has type int, not unsigned long long.                   
                                                                                
    So this expression:                                                         
                                                                                
                                                                                
     1 << width                                                                 
                                                                                
                                                                                
    is evaluated as an int shift before the cast happens.                       
                                                                                
    On the target platform, int is 32 bits. For a left shift, the shift         
    exponent must be:                                                           
                                                                                
                                                                                
     0 <= width < number_of_bits_in_left_operand_type                           
                                                                                
                                                                                
    Here, the left operand type is int, which is 32 bits, but width is 64.      
                                                                                
    So the program attempts:                                                    
                                                                                
                                                                                
     1 << 64                                                                    
                                                                                
                                                                                
    where 1 is a 32-bit int.                                                    
                                                                                
    That is invalid because 64 >= 32.                                           
                                                                                
    UBSan reports this as:                                                      
                                                                                
                                                                                
     Invalid shift exponent                                                     
                                                                                
                                                                                
    The cast here:                                                              
                                                                                
                                                                                
     (unsigned long long)(1 << width)                                           
                                                                                
                                                                                
    does not help, because it happens after the undefined shift has already     
    occurred.                                                                   
                                                                                
    Defect                                                                      
                                                                                
    The defect is that the code shifts an int literal by a value that is too    
    large for int.                                                              
                                                                                
                                                                                
     1 << width                                                                 
                                                                                
                                                                                
    should not be used when width may be greater than or equal to the bit       
    width of int.                                                               
                                                                                
    Additionally, even if this were changed to:                                 
                                                                                
                                                                                
     1ULL << width                                                              
                                                                                
                                                                                
    the call with width == 64 would still be invalid for unsigned long long on  
    a typical 64-bit platform, because shifting a 64-bit integer by 64 is also  
    invalid. Valid shift counts for a 64-bit type are 0 through 63.             
                                                                                
    So there are two issues:                                                    
                                                                                
     1 The literal 1 has the wrong type.                                        
     2 The requested value 2^64 cannot be represented in an unsigned long       
       long.                                                                    
                                                                                
    Minimal local fix                                                           
                                                                                
    If the function is meant to return 2^width as an unsigned long long, then   
    width must be in the range 0..63.                                           
                                                                                
    Use an unsigned long long literal and validate the shift count:             
                                                                                
                                                                                
     #include <stdio.h>                                                         
     #include <limits.h>                                                        
     #include <stdlib.h>                                                        
                                                                                
     static unsigned long long high_bit_mask(int width)                         
     {                                                                          
         int bits = (int)(sizeof(unsigned long long) * CHAR_BIT);               
                                                                                
         if (width < 0 || width >= bits) {                                      
             fprintf(stderr, "invalid width %d: must be in range 0..%d\n",      
                     width, bits - 1);                                          
             exit(1);                                                           
         }                                                                      
                                                                                
         return 1ULL << width;                                                  
     }                                                                          
                                                                                
     int main(void)                                                             
     {                                                                          
         int width = 63;                                                        
         unsigned long long m = high_bit_mask(width);                           
         printf("mask = %llu\n", m);                                            
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    This fixes the immediate undefined behavior.                                
                                                                                
    However, this means width = 64 is rejected, because 2^64 does not fit in    
    unsigned long long.                                                         
                                                                                
    If the intended value is the high bit of a 64-bit value                     
                                                                                
    The function name high_bit_mask suggests that perhaps the caller wants the  
    highest bit set for a width-bit integer. For a 64-bit width, that is not 1  
    << 64; it is 1 << 63.                                                       
                                                                                
    In that case the correct implementation is:                                 
                                                                                
                                                                                
     #include <stdio.h>                                                         
     #include <limits.h>                                                        
     #include <stdlib.h>                                                        
                                                                                
     static unsigned long long high_bit_mask(int width)                         
     {                                                                          
         int bits = (int)(sizeof(unsigned long long) * CHAR_BIT);               
                                                                                
         if (width <= 0 || width > bits) {                                      
             fprintf(stderr, "invalid width %d: must be in range 1..%d\n",      
                     width, bits);                                              
             exit(1);                                                           
         }                                                                      
                                                                                
         return 1ULL << (width - 1);                                            
     }                                                                          
                                                                                
     int main(void)                                                             
     {                                                                          
         int width = 64;                                                        
         unsigned long long m = high_bit_mask(width);                           
         printf("mask = %llu\n", m);                                            
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    For width = 64, this returns:                                               
                                                                                
                                                                                
     1ULL << 63                                                                 
                                                                                
                                                                                
    which is valid and produces the high bit mask for a 64-bit unsigned         
    integer.                                                                    
                                                                                
    If the intended value is a width-bit all-ones mask                          
                                                                                
    If the goal is to produce a mask with width low bits set, then the          
    implementation should special-case the full-width case:                     
                                                                                
                                                                                
     #include <stdio.h>                                                         
     #include <limits.h>                                                        
     #include <stdlib.h>                                                        
                                                                                
     static unsigned long long width_mask(int width)                            
     {                                                                          
         int bits = (int)(sizeof(unsigned long long) * CHAR_BIT);               
                                                                                
         if (width < 0 || width > bits) {                                       
             fprintf(stderr, "invalid width %d: must be in range 0..%d\n",      
                     width, bits);                                              
             exit(1);                                                           
         }                                                                      
                                                                                
         if (width == 0) {                                                      
             return 0;                                                          
         }                                                                      
                                                                                
         if (width == bits) {                                                   
             return ULLONG_MAX;                                                 
         }                                                                      
                                                                                
         return (1ULL << width) - 1;                                            
     }                                                                          
                                                                                
     int main(void)                                                             
     {                                                                          
         int width = 64;                                                        
         unsigned long long m = width_mask(width);                              
         printf("mask = %llu\n", m);                                            
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    This avoids 1ULL << 64, which would also be undefined.                      
                                                                                
    More thorough root-cause fix                                                
                                                                                
    The deeper issue is that the function does not define or enforce the valid  
    domain of width.                                                            
                                                                                
    The code needs to decide what width means:                                  
                                                                                
     • If width is an exponent and the function returns 2^width, then width ==  
       64 cannot be represented in unsigned long long.                          
     • If width is a bit width and the function returns the high bit mask,      
       then the shift should be width - 1.                                      
     • If width is a bit width and the function returns a low-bits mask, then   
       width == 64 needs a special case returning ULLONG_MAX.                   
                                                                                
    The current code silently accepts any int width, which allows invalid       
    shift counts.                                                               
                                                                                
    A robust version should validate the input and use an appropriately typed   
    shift base:                                                                 
                                                                                
                                                                                
     1ULL                                                                       
                                                                                
                                                                                
    not:                                                                        
                                                                                
                                                                                
     1                                                                          
                                                                                
                                                                                
    because the latter is only an int.                                          
                                                                                
    Recommendation                                                              
                                                                                
    Fix the function according to the intended semantics. If the goal is a      
    high-bit mask for a width-bit unsigned long long, use:                      
                                                                                
                                                                                
     #include <stdio.h>                                                         
     #include <limits.h>                                                        
     #include <stdlib.h>                                                        
                                                                                
     static unsigned long long high_bit_mask(int width)                         
     {                                                                          
         int bits = (int)(sizeof(unsigned long long) * CHAR_BIT);               
                                                                                
         if (width <= 0 || width > bits) {                                      
             fprintf(stderr, "invalid width %d: must be in range 1..%d\n",      
                     width, bits);                                              
             exit(1);                                                           
         }                                                                      
                                                                                
         return 1ULL << (width - 1);                                            
     }                                                                          
                                                                                
     int main(void)                                                             
     {                                                                          
         int width = 64;                                                        
         unsigned long long m = high_bit_mask(width);                           
         printf("mask = %llu\n", m);                                            
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    If the goal is literally 2^width, then width = 64 is not representable in   
    unsigned long long; reject it or use a wider type such as unsigned          
    __int128.                                                                   
                                                                                
