   int main() {
       std::unique_ptr<int> n = std::make_unique<int>(100);
       doSomething(n.get());          // pass the raw pointer safely
       std::cout << "n = " << *n.get() << std::endl;
       // unique_ptr automatically deletes n when it goes out of scope
   }
   ```
   
   Using smart pointers enforces proper ownership semantics and eliminates the
   class of errors associated with manual `new`/`delete` pair mismatches,
   preventing dangling pointer bugs across the entire codebase.
