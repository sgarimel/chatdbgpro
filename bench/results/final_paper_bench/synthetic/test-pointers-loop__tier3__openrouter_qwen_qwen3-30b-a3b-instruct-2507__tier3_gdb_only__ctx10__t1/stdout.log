   ```cpp
   #include <memory>
   
   struct Node {
       int data;
       std::unique_ptr<Node> next;
   
       Node(int value) : data(value), next(nullptr) {}
   };
   
   int main()
   {
       auto node1 = std::make_unique<Node>(10);
       auto node2 = std::make_unique<Node>(20);
       auto node3 = std::make_unique<Node>(30);
   
       node1->next = std::move(node2);
       node2->next = std::move(node1);
   
       // Safe access: check if next exists
       if (node3->next) {
           Node& n = *node3->next;  // Now safe: next is non-null or will fail at construction
       } else {
           // handle case
       }
   
       return 0;
   }
   ```
   
