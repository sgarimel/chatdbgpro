   +  if (node3->next != nullptr) {
   +    Node n = *node3->next;
   +  }
   ```
   
   GLOBAL FIX: Make the nullability/invariant explicit instead of exposing a raw
   public pointer. For example, make `next` private and provide a checked
   accessor:
   
   ```cpp
   class Node {
   public:
       int data;
   
       explicit Node(int value) : data(value), next_(nullptr) {}
   
       void setNext(Node* next) {
           next_ = next;
       }
   
       bool hasNext() const {
           return next_ != nullptr;
       }
   
       Node& next() {
           if (next_ == nullptr) {
               throw std::logic_error("Node::next called on node with no next");
           }
           return *next_;
       }
   
   private:
       Node* next_;
   };
   ```
   
   Then the use site becomes:
   
   ```cpp
