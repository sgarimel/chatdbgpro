       char *pbuf = malloc(strlen(argc[2]) + 1);
       if (pbuf == NULL) {
           perror("malloc failed for pbuf");
           return 1;
       }
   
       // Safely copy argc[2] to pbuf
       strcpy(pbuf, argc[2]);
   
       // Determine the required size for buf based on argc[1]
       size_t buf_len = strlen(argc[1]) + 1;
       char *buf = malloc(buf_len); // Dynamically allocate buf
       if (buf == NULL) {
           perror("malloc failed for buf");
           free(pbuf); // Free previously allocated memory
           return 1;
       }
   
       // Safely copy argc[1] to buf
       strcpy(buf, argc[1]);
   
       // Use buf and pbuf
       printf("buf: %s\n", buf);
       printf("pbuf: %s\n", pbuf);
   
       // Free dynamically allocated memory
       free(pbuf);
       free(buf);
   
       return 0;
   }
