    I inspected the source around the reported function and confirmed the       
    crash is caused by unbounded copying into fixed-size character arrays.      
                                                                                
    The relevant constants and globals are:                                     
                                                                                
                                                                                
     /* polymorph_types.h */                                                    
     #define MAX  2048                                                          
                                                                                
                                                                                
                                                                                
     /* polymorph.c */                                                          
     char tmpbuf[MAX], target[MAX], wd[MAX];                                    
                                                                                
                                                                                
    The command line uses -f with a filename longer than 2048 bytes. That       
    argument is first copied here:                                              
                                                                                
                                                                                
     /* polymorph.c */                                                          
     case 'f':                                                                  
         strcpy( target, optarg );                                              
         break;                                                                 
                                                                                
                                                                                
    target is only MAX bytes long, so this is already an overflow if optarg is  
    2048 bytes or longer including the terminating '\0'.                        
                                                                                
    Then main() passes target into convert_fileName():                          
                                                                                
                                                                                
     if( strlen(target) != 0 ){                                                 
         convert_fileName( target );                                            
         return( 0 );                                                           
     }                                                                          
                                                                                
                                                                                
    Inside convert_fileName() there is another fixed-size buffer:               
                                                                                
                                                                                
     void convert_fileName(char *original){                                     
         char newname[MAX];                                                     
         ...                                                                    
                                                                                
                                                                                
    The conversion loop copies the entire input string into newname one byte    
    at a time:                                                                  
                                                                                
                                                                                
     if( does_nameHaveUppers( original ) ){                                     
         /* convert the filename */                                             
         for(i=0;i<strlen(original);i++){                                       
             if( isupper( original[i] ) ){                                      
                 newname[i] = tolower( original[i] );                           
                 continue;                                                      
             }                                                                  
             newname[i] = original[i];                                          
         }                                                                      
         newname[i] = '\0';                                                     
     }else{                                                                     
         strcpy( newname, original );                                           
         error = -1;                                                            
     }                                                                          
                                                                                
                                                                                
    For the failing input, original points to the long -f argument consisting   
    of thousands of uppercase A characters. Therefore:                          
                                                                                
     1 is_fileHidden(original) returns false because original[0] == 'A', not    
       '.'.                                                                     
     2 does_nameHaveUppers(original) returns true immediately because           
       original[0] is uppercase.                                                
     3 The uppercase-conversion branch runs.                                    
     4 strlen(original) is greater than MAX.                                    
     5 The loop writes:                                                         
        • newname[0] = 'a'                                                      
        • ...                                                                   
        • newname[2047] = 'a'                                                   
        • newname[2048] = 'a' ← first byte past the end of char newname[2048]   
        • more bytes after that, corrupting the stack frame.                    
     6 After the loop, newname[i] = '\0' also writes past the end when i >=     
       MAX.                                                                     
                                                                                
    Because newname is a stack buffer, writing beyond it corrupts adjacent      
    stack data, including saved frame metadata and potentially the return       
    address. That explains the stack-buffer-overflow crash.                     
                                                                                
    There are actually two closely related defects:                             
                                                                                
     • grok_commandLine() uses strcpy(target, optarg) into a global             
       target[MAX].                                                             
     • convert_fileName() copies original into stack buffer newname[MAX]        
       without checking that the input fits.                                    
                                                                                
    The stack overflow described in the prompt is specifically in               
    convert_fileName(), but a correct fix should also stop the earlier          
    overflow into target.                                                       
                                                                                
    A minimal local fix is to reject or truncate names that do not fit before   
    copying. Since this program is renaming files, silently truncating is       
    dangerous because it can rename to the wrong target. It should reject       
    overlong names.                                                             
                                                                                
    One possible local patch:                                                   
                                                                                
                                                                                
     diff --git a/polymorph.c b/polymorph.c                                     
     index ... .. ...                                                           
     --- a/polymorph.c                                                          
     +++ b/polymorph.c                                                          
     @@ -117,7 +117,12 @@ void grok_commandLine(int argc, char *argv[]){        
                              clean = 1;                                        
                              break;                                            
                      case 'f':                                                 
     -                        strcpy( target, optarg );                         
     +                        if (strlen(optarg) >= sizeof(target)) {           
     +                                fprintf(stderr, "filename too long:       
     maximum is %zu bytes\n",                                                   
     +                                        sizeof(target) - 1);              
     +                                exit(1);                                  
     +                        }                                                 
     +                        strcpy( target, optarg );                         
                              break;                                            
                      case 'h':                                                 
                              fprintf( stderr,"polymorph v%s -- filename        
     convertor\n", VERSION );                                                   
     @@ -184,6 +189,12 @@ void convert_fileName(char *original){                
                                                                                
          error = 0;                                                            
          strcpy( newname, "" );                                                
     +                                                                          
     +    if (strlen(original) >= sizeof(newname)) {                            
     +        fprintf(stderr, "filename too long: maximum is %zu bytes\n",      
     +                sizeof(newname) - 1);                                     
     +        return;                                                           
     +    }                                                                     
                                                                                
          if( is_fileHidden( original ) && !hidden ) return;                    
                                                                                
                                                                                
    After that length check, the existing loop cannot write past newname[MAX -  
    1], and the terminating null byte also fits.                                
                                                                                
    The loop should also avoid repeatedly calling strlen(original) and should   
    cast to unsigned char before using isupper()/tolower():                     
                                                                                
                                                                                
     size_t len = strlen(original);                                             
                                                                                
     if (len >= sizeof(newname)) {                                              
         fprintf(stderr, "filename too long: maximum is %zu bytes\n",           
     sizeof(newname) - 1);                                                      
         return;                                                                
     }                                                                          
                                                                                
     if (does_nameHaveUppers(original)) {                                       
         for (size_t i = 0; i < len; i++) {                                     
             unsigned char ch = (unsigned char)original[i];                     
             newname[i] = isupper(ch) ? (char)tolower(ch) : (char)ch;           
         }                                                                      
         newname[len] = '\0';                                                   
     } else {                                                                   
         memcpy(newname, original, len + 1);                                    
         error = -1;                                                            
     }                                                                          
                                                                                
                                                                                
    A more thorough fix would remove the arbitrary stack-sized copy from the    
    design. convert_fileName() can allocate the destination name based on the   
    actual input length, then validate against filesystem limits separately if  
    desired. For example:                                                       
                                                                                
                                                                                
     void convert_fileName(char *original)                                      
     {                                                                          
         size_t len;                                                            
         char *newname;                                                         
         char *bslash;                                                          
         int error = 0;                                                         
                                                                                
         if (original == NULL) {                                                
             return;                                                            
         }                                                                      
                                                                                
         if (is_fileHidden(original) && !hidden) {                              
             return;                                                            
         }                                                                      
                                                                                
         len = strlen(original);                                                
         newname = malloc(len + 1);                                             
         if (newname == NULL) {                                                 
             fprintf(stderr, "out of memory\n");                                
             exit(1);                                                           
         }                                                                      
                                                                                
         if (does_nameHaveUppers(original)) {                                   
             for (size_t i = 0; i < len; i++) {                                 
                 unsigned char ch = (unsigned char)original[i];                 
                 newname[i] = isupper(ch) ? (char)tolower(ch) : (char)ch;       
             }                                                                  
             newname[len] = '\0';                                               
         } else {                                                               
             memcpy(newname, original, len + 1);                                
             error = -1;                                                        
         }                                                                      
                                                                                
         if (clean) {                                                           
             bslash = strrchr(newname, '\\');                                   
             if (bslash != NULL) {                                              
                 memmove(newname, bslash + 1, strlen(bslash + 1) + 1);          
             }                                                                  
         }                                                                      
                                                                                
         if (error != -1) {                                                     
             error = does_newnameExist(newname);                                
             if (error) {                                                       
                 fprintf(stderr, "target exists -- skipping %s...\n",           
     original);                                                                 
                 free(newname);                                                 
                 return;                                                        
             }                                                                  
         }                                                                      
                                                                                
         error = rename(original, newname);                                     
         if (error) {                                                           
             fprintf(stderr,                                                    
                     "polymorph had trouble converting %s to %s...\n",          
                     original,                                                  
                     newname);                                                  
