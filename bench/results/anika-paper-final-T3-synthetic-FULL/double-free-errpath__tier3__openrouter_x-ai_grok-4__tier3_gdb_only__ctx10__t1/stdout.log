   struct Blob
   {
     char *name; /* on heap! */
     int b_length;
     unsigned char *b_data;
   };
   
   typedef struct Blob blob_t;
   
   blob_t* load_blob(const char *name)
   {
     blob_t *b = (blob_t *)malloc(sizeof(blob_t));
     if (b == NULL)
       return NULL;
     /* pretend to load to b->b_data */
     b->b_data = (unsigned char *)strdup("dummy");
     b->b_length = strlen("dummy") + 1;
     b->name = strdup(name);
     if (b->b_data == NULL || b->name == NULL)
       {
         free(b->name); /* free if allocated */
         free(b->b_data);
         free(b);
         return NULL;
       }
     return b;
   }
   
   void destroy_blob(blob_t *b)
   {
     free(b->name); /* free it again! */
     if (b->b_data != NULL) {
       if (b->b_length > 0x0fffffff) {
         printf("too biG!?\n");
         *(int *)NULL = 0;
       }
       free(b->b_data);
     }
     free(b);
   }
   
