   {
     blob_t* blob = (argc > 1) ? load_blob(argv[1]) : load_blob("default");
     if (!blob)
       {
         printf( "Unable to load!\n");
         return 2;
       }
   
     if (rand() % 2) {
       free(blob->name);
       blob->name = NULL;
     }
     destroy_blob(blob);
     return 0;
   }
   
   
