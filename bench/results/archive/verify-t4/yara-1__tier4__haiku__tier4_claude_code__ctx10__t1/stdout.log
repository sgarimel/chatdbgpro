,8 @@ int main(int argc, char** argv)\n   test_save_load_rules();\n   test_scanner();\n   test_ast_callback();\n-  test_issue_834();\n   test_rules_stats();\n+\n+  test_issue_834();\n+  test_issue_920();\n }","is_error":false}]},"parent_tool_use_id":null,"session_id":"99c9b849-aaad-4ab2-b5f1-dc1bdbf50604","uuid":"22678cff-c1c8-4db1-86d0-86573ceddad4","timestamp":"2026-05-02T20:58:09.207Z","tool_use_result":{"stdout":"commit cb787cc0c7edd91d245175af439a9190da97228b\nAuthor: Victor M. Alvarez <vmalvarez@virustotal.com>\nDate:   Wed Jul 25 13:26:52 2018 +0200\n\n    Fix issue #920.\n\ndiff --git a/libyara/parser.c b/libyara/parser.c\nindex 6789a341..dd696f6d 100644\n--- a/libyara/parser.c\n+++ b/libyara/parser.c\n@@ -730,7 +730,7 @@ int yr_parser_reduce_rule_declaration_phase_1(\n       yr_hash_table_lookup(\n         compiler->objects_table,\n         identifier,\n-        compiler->current_namespace->name) != NULL)\n+        NULL) != NULL)\n   {\n     // A rule or variable with the same identifier already exists, return the\n     // appropriate error.\ndiff --git a/tests/test-api.c b/tests/test-api.c\nindex b2c5ef8d..c0877e7c 100644\n--- a/tests/test-api.c\n+++ b/tests/test-api.c\n@@ -694,6 +694,42 @@ void test_rules_stats()\n }\n \n \n+void test_issue_920()\n+{\n+  const char* rules_str = \"\\\n+      rule test { \\\n+        condition: true \\\n+      }\";\n+\n+  YR_COMPILER* compiler = NULL;\n+\n+  yr_initialize();\n+\n+  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n+  {\n+    perror(\"yr_compiler_create\");\n+    exit(EXIT_FAILURE);\n+  }\n+\n+  // Define a variable named \"test\"\n+  yr_compiler_define_boolean_variable(compiler, \"test\", 1);\n+\n+  // The compilation should not succeed, as the rule is named \"test\" and a\n+  // a variable with the same name already exists.\n+  yr_compiler_add_string(compiler, rules_str, NULL);\n+\n+  if (compiler->last_error != ERROR_DUPLICATED_IDENTIFIER)\n+  {\n+    yr_compiler_destroy(compiler);\n+    printf(\"expec