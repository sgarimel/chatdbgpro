{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0124usmPB5wKoPRpWMik2isq","type":"tool_result","content":"1\t\n2\t#include <yara.h>\n3\t#include \"util.h\"\n4\t\n5\t#if defined(_WIN32) || defined(__CYGWIN__)\n6\t#include <fileapi.h>\n7\t#else\n8\t#include <unistd.h>\n9\t#endif\n10\t#include <fcntl.h>\n11\t\n12\t#include \"defects4cpp.h\"\n13\t\n14\tvoid test_disabled_rules()\n15\t{\n16\t  YR_RULES* rules;\n17\t  YR_RULE* rule;\n18\t\n19\t  int matches = 0;\n20\t  char* buf = \"foo bar\";\n21\t  char* rules_str = \" \\\n22\t    rule disabled_rule {condition: true} \\\n23\t    rule false_rule {condition: true and disabled_rule} \\\n24\t    rule true_rule {condition: true or disabled_rule}\";\n25\t\n26\t\n27\t  yr_initialize();\n28\t\n29\t  if (compile_rule(rules_str, &rules) != ERROR_SUCCESS)\n30\t  {\n31\t    perror(\"compile_rule\");\n32\t    exit(EXIT_FAILURE);\n33\t  }\n34\t\n35\t  // diable any rule containing disable in its identifier\n36\t  yr_rules_foreach(rules, rule)\n37\t  {\n38\t    if (strstr(rule->identifier, \"disabled\"))\n39\t      yr_rule_disable(rule);\n40\t  }\n41\t\n42\t  yr_rules_scan_mem(\n43\t      rules, (uint8_t *) buf, strlen(buf), 0, count_matches, &matches, 0);\n44\t\n45\t  yr_rules_destroy(rules);\n46\t\n47\t  // matches should be exactly one.\n48\t  if (matches != 1)\n49\t  {\n50\t    fprintf(stderr, \"test_disabled_rules failed\\n\");\n51\t    exit(EXIT_FAILURE);\n52\t  }\n53\t\n54\t  yr_finalize();\n55\t}\n56\t\n57\t\n58\tconst char* _include_callback(\n59\t  const char* include_name,\n60\t  const char* calling_rule_filename,\n61\t  const char* calling_rule_namespace,\n62\t  void* user_data)\n63\t{\n64\tif (strcmp(include_name, \"ok\") == 0)\n65\t  return \"rule test {condition: true}\";\n66\telse\n67\t  return NULL;\n68\t}\n69\t\n70\t\n71\tvoid test_include_callback()\n72\t{\n73\t  YR_COMPILER* compiler = NULL;\n74\t\n75\t  yr_initialize();\n76\t\n77\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n78\t  {\n79\t    perror(\"yr_compiler_create\");\n80\t    exit(EXIT_FAILURE);\n81\t  }\n82\t\n83\t  yr_compiler_set_include_callback(compiler, _include_callback, NULL, NULL);\n84\t\n85\t  // This include produces no error.\n86\t  if (yr_compiler_add_string(compiler, \"include \\\"ok\\\"\", NULL) != 0)\n87\t  {\n88\t    yr_compiler_destroy(compiler);\n89\t    exit(EXIT_FAILURE);\n90\t  }\n91\t\n92\t  // This include one error.\n93\t  if (yr_compiler_add_string(compiler, \"include \\\"fail\\\"\", NULL) != 1)\n94\t  {\n95\t    yr_compiler_destroy(compiler);\n96\t    exit(EXIT_FAILURE);\n97\t  }\n98\t\n99\t  yr_compiler_destroy(compiler);\n100\t  yr_finalize();\n101\t}\n102\t\n103\t\n104\tvoid test_file_descriptor()\n105\t{\n106\t  YR_COMPILER* compiler = NULL;\n107\t  YR_RULES* rules = NULL;\n108\t\n109\t#if defined(_WIN32) || defined(__CYGWIN__)\n110\t  HANDLE fd = CreateFile(\"tests/data/baz.yar\", GENERIC_READ, 0, NULL, OPEN_EXISTING, 0, NULL);\n111\t  if (fd == INVALID_HANDLE_VALUE)\n112\t  {\n113\t    fputs(\"CreateFile failed\", stderr);\n114\t    exit(1);\n115\t  }\n116\t#else\n117\t  int fd = open(\"tests/data/baz.yar\", O_RDONLY);\n118\t  if (fd < 0)\n119\t  {\n120\t    perror(\"open\");\n121\t    exit(EXIT_FAILURE);\n122\t  }\n123\t#endif\n124\t\n125\t  yr_initialize();\n126\t\n127\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n128\t  {\n129\t    perror(\"yr_compiler_create\");\n130\t    exit(EXIT_FAILURE);\n131\t  }\n132\t\n133\t  if (yr_compiler_add_fd(compiler, fd, NULL, NULL) != 0)\n134\t  {\n135\t    perror(\"yr_compiler_add_fd\");\n136\t    exit(EXIT_FAILURE);\n137\t  }\n138\t\n139\t#if defined(_WIN32) || defined(__CYGWIN__)\n140\t  CloseHandle(fd);\n141\t#else\n142\t  close(fd);\n143\t#endif\n144\t\n145\t  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n146\t  {\n147\t    perror(\"yr_compiler_add_fd\");\n148\t    exit(EXIT_FAILURE);\n149\t  }\n150\t\n151\t  if (compiler)\n152\t    yr_compiler_destroy(compiler);\n153\t\n154\t  if (rules)\n155\t    yr_rules_destroy(rules);\n156\t\n157\t  yr_finalize();\n158\t\n159\t  return;\n160\t}\n161\t\n162\tvoid test_max_string_per_rules()\n163\t{\n164\t  uint32_t new_max_strings_per_rule = 1;\n165\t  uint32_t old_max_strings_per_rule;\n166\t\n167\t  yr_initialize();\n168\t\n169\t  yr_get_configuration(\n170\t      YR_CONFIG_MAX_STRINGS_PER_RULE,\n171\t      (void*) &old_max_strings_per_rule);\n172\t\n173\t  yr_set_configuration(\n174\t      YR_CONFIG_MAX_STRINGS_PER_RULE,\n175\t      (void*) &new_max_strings_per_rule);\n176\t\n177\t  assert_error(\n178\t      \"rule test { \\\n179\t         strings: \\\n180\t           $ = \\\"uno\\\" \\\n181\t           $ = \\\"dos\\\" \\\n182\t         condition: \\\n183\t           all of them }\",\n184\t      ERROR_TOO_MANY_STRINGS);\n185\t\n186\t  new_max_strings_per_rule = 2;\n187\t\n188\t  yr_set_configuration(\n189\t      YR_CONFIG_MAX_STRINGS_PER_RULE,\n190\t      (void*) &new_max_strings_per_rule);\n191\t\n192\t  assert_error(\n193\t      \"rule test { \\\n194\t         strings: \\\n195\t           $ = \\\"uno\\\" \\\n196\t           $ = \\\"dos\\\" \\\n197\t         condition: \\\n198\t           all of them }\",\n199\t      ERROR_SUCCESS);\n200\t\n201\t  yr_set_configuration(\n202\t      YR_CONFIG_MAX_STRINGS_PER_RULE,\n203\t      (void*) &old_max_strings_per_rule);\n204\t\n205\t  yr_finalize();\n206\t}\n207\t\n208\t\n209\tint test_max_match_data_callback(\n210\t    int message,\n211\t    void* message_data,\n212\t    void* user_data)\n213\t{\n214\t  if (message == CALLBACK_MSG_RULE_MATCHING)\n215\t  {\n216\t    YR_RULE* r = (YR_RULE*) message_data;\n217\t    YR_STRING* s;\n218\t\n219\t    yr_rule_strings_foreach(r, s)\n220\t    {\n221\t      YR_MATCH* m;\n222\t\n223\t      yr_string_matches_foreach(s, m)\n224\t      {\n225\t        if (m->data_length > 0)\n226\t          return CALLBACK_ERROR;\n227\t      }\n228\t    }\n229\t  }\n230\t\n231\t  return CALLBACK_CONTINUE;\n232\t}\n233\t\n234\tvoid test_max_match_data()\n235\t{\n236\t  YR_RULES* rules;\n237\t\n238\t  uint32_t new_max_match_data = 0;\n239\t  uint32_t old_max_match_data;\n240\t\n241\t  char* rules_str = \"rule t { strings: $a = \\\"foobar\\\" condition: $a }\";\n242\t\n243\t  yr_initialize();\n244\t\n245\t  yr_get_configuration(\n246\t      YR_CONFIG_MAX_MATCH_DATA,\n247\t      (void*) &old_max_match_data);\n248\t\n249\t  yr_set_configuration(\n250\t      YR_CONFIG_MAX_MATCH_DATA,\n251\t      (void*) &new_max_match_data);\n252\t\n253\t  if (compile_rule(rules_str, &rules) != ERROR_SUCCESS)\n254\t  {\n255\t    perror(\"compile_rule\");\n256\t    exit(EXIT_FAILURE);\n257\t  }\n258\t\n259\t  int err = yr_rules_scan_mem(\n260\t      rules,\n261\t      (const uint8_t *) \"foobar\",\n262\t      6,\n263\t      0,\n264\t      test_max_match_data_callback,\n265\t      NULL,\n266\t      0);\n267\t\n268\t  if (err != ERROR_SUCCESS)\n269\t  {\n270\t    fprintf(stderr, \"test_max_match_data failed\");\n271\t    exit(EXIT_FAILURE);\n272\t  }\n273\t\n274\t  yr_rules_destroy(rules);\n275\t  yr_finalize();\n276\t}\n277\t\n278\t\n279\tvoid test_save_load_rules()\n280\t{\n281\t  YR_COMPILER* compiler = NULL;\n282\t  YR_RULES* rules = NULL;\n283\t\n284\t  int matches = 0;\n285\t  char* rules_str = \"rule t {condition: bool_var and str_var == \\\"foobar\\\"}\";\n286\t\n287\t  yr_initialize();\n288\t\n289\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n290\t  {\n291\t    perror(\"yr_compiler_create\");\n292\t    exit(EXIT_FAILURE);\n293\t  }\n294\t\n295\t  yr_compiler_define_boolean_variable(compiler, \"bool_var\", 1);\n296\t  yr_compiler_define_string_variable(compiler, \"str_var\", \"foobar\");\n297\t\n298\t  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n299\t  {\n300\t    yr_compiler_destroy(compiler);\n301\t    perror(\"yr_compiler_add_string\");\n302\t    exit(EXIT_FAILURE);\n303\t  }\n304\t\n305\t  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n306\t  {\n307\t    yr_compiler_destroy(compiler);\n308\t    perror(\"yr_compiler_add_fd\");\n309\t    exit(EXIT_FAILURE);\n310\t  }\n311\t\n312\t  yr_compiler_destroy(compiler);\n313\t\n314\t  if (yr_rules_save(rules, \"test-rules.yarc\") != ERROR_SUCCESS)\n315\t  {\n316\t    yr_rules_destroy(rules);\n317\t    perror(\"yr_rules_save\");\n318\t    exit(EXIT_FAILURE);\n319\t  }\n320\t\n321\t  yr_rules_destroy(rules);\n322\t\n323\t  if (yr_rules_load(\"test-rules.yarc\", &rules) != ERROR_SUCCESS)\n324\t  {\n325\t    perror(\"yr_rules_load\");\n326\t    exit(EXIT_FAILURE);\n327\t  }\n328\t\n329\t  int err = yr_rules_scan_mem(\n330\t      rules,\n331\t      (uint8_t *) \"\",\n332\t       0,\n333\t       0,\n334\t       count_matches,\n335\t       &matches,\n336\t       0);\n337\t\n338\t  if (err != ERROR_SUCCESS)\n339\t  {\n340\t    fprintf(stderr, \"test_save_load_rules: error: %d\\n\", err);\n341\t    exit(EXIT_FAILURE);\n342\t  }\n343\t\n344\t  if (matches != 1)\n345\t  {\n346\t    fprintf(stderr, \"test_save_load_rules: expecting 1 match, got: %d\\n\", matches);\n347\t    exit(EXIT_FAILURE);\n348\t  }\n349\t\n350\t  yr_rules_destroy(rules);\n351\t  yr_finalize();\n352\t}\n353\t\n354\t\n355\tvoid test_scanner()\n356\t{\n357\t  int matches = 0;\n358\t  const char* buf = \"dummy\";\n359\t  const char* rules_str = \"\\\n360\t    rule test { \\\n361\t    condition: bool_var and int_var == 1 and str_var == \\\"foo\\\" }\";\n362\t\n363\t  YR_COMPILER* compiler = NULL;\n364\t  YR_RULES* rules = NULL;\n365\t  YR_SCANNER* scanner1 = NULL;\n366\t  YR_SCANNER* scanner2 = NULL;\n367\t\n368\t  int result;\n369\t\n370\t  yr_initialize();\n371\t\n372\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n373\t  {\n374\t    perror(\"yr_compiler_create\");\n375\t    exit(EXIT_FAILURE);\n376\t  }\n377\t\n378\t  // Define a few variables\n379\t  yr_compiler_define_integer_variable(compiler, \"int_var\", 0);\n380\t  yr_compiler_define_boolean_variable(compiler, \"bool_var\", 0);\n381\t  yr_compiler_define_string_variable(compiler, \"str_var\", \"\");\n382\t\n383\t\n384\t  if (yr_compiler_define_string_variable(\n385\t      compiler, \"str_var\", \"\") != ERROR_DUPLICATED_EXTERNAL_VARIABLE)\n386\t  {\n387\t    yr_compiler_destroy(compiler);\n388\t    perror(\"expecting ERROR_DUPLICATED_EXTERNAL_VARIABLE\");\n389\t    exit(EXIT_FAILURE);\n390\t  }\n391\t\n392\t  // Compile a rule that use the variables in the condition.\n393\t  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n394\t  {\n395\t    yr_compiler_destroy(compiler);\n396\t    perror(\"yr_compiler_add_string\");\n397\t    exit(EXIT_FAILURE);\n398\t  }\n399\t\n400\t  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n401\t  {\n402\t    yr_compiler_destroy(compiler);\n403\t    perror(\"yr_compiler_get_rules\");\n404\t    exit(EXIT_FAILURE);\n405\t  }\n406\t\n407\t  yr_compiler_destroy(compiler);\n408\t\n409\t  // Create an scanner\n410\t  if (yr_scanner_create(rules, &scanner1)!= ERROR_SUCCESS)\n411\t  {\n412\t    yr_rules_destroy(rules);\n413\t    perror(\"yr_scanner_create\");\n414\t    exit(EXIT_FAILURE);\n415\t  }\n416\t\n417\t  // Create another scanner\n418\t  if (yr_scanner_create(rules, &scanner2)!= ERROR_SUCCESS)\n419\t  {\n420\t    yr_scanner_destroy(scanner1);\n421\t    yr_rules_destroy(rules);\n422\t    perror(\"yr_scanner_create\");\n423\t    exit(EXIT_FAILURE);\n424\t  }\n425\t\n426\t  // Let's check the yr_scanner_scan_mem returns the appropriate error when\n427\t  // called without specifying a callback.\n428\t  result = yr_scanner_scan_mem(scanner1, (uint8_t *) buf, strlen(buf));\n429\t\n430\t  if (result != ERROR_CALLBACK_REQUIRED)\n431\t  {\n432\t    yr_scanner_destroy(scanner1);\n433\t    yr_scanner_destroy(scanner2);\n434\t    yr_rules_destroy(rules);\n435\t    printf(\"expecting ERROR_CALLBACK_REQUIRED (%d), got: %d\\n\",\n436\t           ERROR_CALLBACK_REQUIRED, result);\n437\t    exit(EXIT_FAILURE);\n438\t  }\n439\t\n440\t  // Set the callback and a some the correct values for the rule to match.\n441\t  yr_scanner_set_callback(scanner1, count_matches, &matches);\n442\t  yr_scanner_define_integer_variable(scanner1, \"int_var\", 1);\n443\t  yr_scanner_define_boolean_variable(scanner1, \"bool_var\", 1);\n444\t  yr_scanner_define_string_variable(scanner1, \"str_var\", \"foo\");\n445\t\n446\t  // Set some other values for the second scanner to make sure it doesn't\n447\t  // interfere with the first one.\n448\t  yr_scanner_define_integer_variable(scanner2, \"int_var\", 2);\n449\t  yr_scanner_define_boolean_variable(scanner2, \"bool_var\", 0);\n450\t  yr_scanner_define_string_variable(scanner2, \"str_var\", \"bar\");\n451\t\n452\t  result = yr_scanner_scan_mem(scanner1, (uint8_t *) buf, strlen(buf));\n453\t\n454\t  if (result != ERROR_SUCCESS)\n455\t  {\n456\t    yr_scanner_destroy(scanner1);\n457\t    yr_scanner_destroy(scanner2);\n458\t    yr_rules_destroy(rules);\n459\t    printf(\"expecting ERROR_SUCCESS (%d), got: %d\\n\",\n460\t           ERROR_SUCCESS, result);\n461\t    exit(EXIT_FAILURE);\n462\t  }\n463\t\n464\t  if (matches != 1)\n465\t  {\n466\t    yr_scanner_destroy(scanner1);\n467\t    yr_scanner_destroy(scanner2);\n468\t    yr_rules_destroy(rules);\n469\t    exit(EXIT_FAILURE);\n470\t  }\n471\t\n472\t  yr_scanner_destroy(scanner1);\n473\t  yr_scanner_destroy(scanner2);\n474\t  yr_rules_destroy(rules);\n475\t  yr_finalize();\n476\t}\n477\t\n478\t// Test case for https://github.com/VirusTotal/yara/issues/834. Use the same\n479\t// scanner for scanning multiple files with a rule that imports the \"tests\"\n480\t// module. If the unload_module function is called twice an assertion is\n481\t// triggered by the module.\n482\tvoid test_issue_834()\n483\t{\n484\t  const char* buf = \"dummy\";\n485\t  const char* rules_str = \"import \\\"tests\\\" rule test { condition: true }\";\n486\t\n487\t  YR_COMPILER* compiler = NULL;\n488\t  YR_RULES* rules = NULL;\n489\t  YR_SCANNER* scanner = NULL;\n490\t\n491\t  yr_initialize();\n492\t\n493\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n494\t  {\n495\t    perror(\"yr_compiler_create\");\n496\t    exit(EXIT_FAILURE);\n497\t  }\n498\t\n499\t  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n500\t  {\n501\t    yr_compiler_destroy(compiler);\n502\t    perror(\"yr_compiler_add_string\");\n503\t    exit(EXIT_FAILURE);\n504\t  }\n505\t\n506\t  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n507\t  {\n508\t    yr_compiler_destroy(compiler);\n509\t    perror(\"yr_compiler_get_rules\");\n510\t    exit(EXIT_FAILURE);\n511\t  }\n512\t\n513\t  yr_compiler_destroy(compiler);\n514\t\n515\t  if (yr_scanner_create(rules, &scanner)!= ERROR_SUCCESS)\n516\t  {\n517\t    yr_rules_destroy(rules);\n518\t    perror(\"yr_scanner_create\");\n519\t    exit(EXIT_FAILURE);\n520\t  }\n521\t\n522\t  yr_scanner_set_callback(scanner, do_nothing, NULL);\n523\t\n524\t  // Call yr_scanner_scan_mem twice.\n525\t  yr_scanner_scan_mem(scanner, (uint8_t *) buf, strlen(buf));\n526\t  yr_scanner_scan_mem(scanner, (uint8_t *) buf, strlen(buf));\n527\t\n528\t  yr_scanner_destroy(scanner);\n529\t  yr_rules_destroy(rules);\n530\t  yr_finalize();\n531\t}\n532\t\n533\t\n534\tvoid ast_callback(\n535\t    const YR_RULE* rule,\n536\t    const char* string_identifier,\n537\t    const RE_AST* re_ast,\n538\t    void* user_data)\n539\t{\n540\t  if (strcmp(rule->identifier, \"test\") == 0 &&\n541\t      strcmp(string_identifier, \"$foo\") == 0)\n542\t  {\n543\t    *((int*) user_data) = 1;\n544\t  }\n545\t}\n546\t\n547\tvoid test_ast_callback()\n548\t{\n549\t  const char* rules_str = \"\\\n550\t      rule test { \\\n551\t      strings: $foo = /a.*b/ \\\n552\t      condition: $foo }\";\n553\t\n554\t  YR_COMPILER* compiler = NULL;\n555\t\n556\t  yr_initialize();\n557\t\n558\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n559\t  {\n560\t    perror(\"yr_compiler_create\");\n561\t    exit(EXIT_FAILURE);\n562\t  }\n563\t\n564\t  int ok = 0;\n565\t\n566\t  yr_compiler_set_re_ast_callback(\n567\t      compiler,\n568\t      ast_callback,\n569\t      &ok);\n570\t\n571\t  // Compile a rule that use the variables in the condition.\n572\t  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n573\t  {\n574\t    yr_compiler_destroy(compiler);\n575\t    perror(\"yr_compiler_add_string\");\n576\t    exit(EXIT_FAILURE);\n577\t  }\n578\t\n579\t  if (!ok)\n580\t  {\n581\t    printf(\"ast callback failed\\n\");\n582\t    exit(EXIT_FAILURE);\n583\t  }\n584\t\n585\t  yr_compiler_destroy(compiler);\n586\t  yr_finalize();\n587\t}\n588\t\n589\t\n590\tvoid stats_for_rules(\n591\t    const char* rules_str,\n592\t    YR_RULES_STATS* stats)\n593\t{\n594\t  YR_COMPILER* compiler = NULL;\n595\t  YR_RULES* rules = NULL;\n596\t\n597\t  yr_initialize();\n598\t\n599\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n600\t  {\n601\t    perror(\"yr_compiler_create\");\n602\t    exit(EXIT_FAILURE);\n603\t  }\n604\t\n605\t  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n606\t  {\n607\t    yr_compiler_destroy(compiler);\n608\t    perror(\"yr_compiler_add_string\");\n609\t    exit(EXIT_FAILURE);\n610\t  }\n611\t\n612\t  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n613\t  {\n614\t    yr_compiler_destroy(compiler);\n615\t    perror(\"yr_compiler_get_rules\");\n616\t    exit(EXIT_FAILURE);\n617\t  }\n618\t\n619\t  yr_rules_get_stats(rules, stats);\n620\t\n621\t  yr_compiler_destroy(compiler);\n622\t  yr_rules_destroy(rules);\n623\t  yr_finalize();\n624\t}\n625\t\n626\t\n627\tvoid test_rules_stats()\n628\t{\n629\t  YR_RULES_STATS stats;\n630\t\n631\t  stats_for_rules(\"\\\n632\t      rule test { \\\n633\t      strings: $ = /.*/ \\\n634\t      condition: all of them }\",\n635\t      &stats);\n636\t\n637\t  assert_true_expr(stats.rules == 1);\n638\t  assert_true_expr(stats.strings == 1);\n639\t  assert_true_expr(stats.ac_root_match_list_length == 1);\n640\t\n641\t  stats_for_rules(\"\\\n642\t      rule test { \\\n643\t      strings: $ = \\\"abc\\\" \\\n644\t      condition: all of them }\",\n645\t      &stats);\n646\t\n647\t  assert_true_expr(stats.rules == 1);\n648\t  assert_true_expr(stats.strings == 1);\n649\t  assert_true_expr(stats.ac_matches == 1);\n650\t  assert_true_expr(stats.ac_root_match_list_length == 0);\n651\t  assert_true_expr(stats.top_ac_match_list_lengths[0] == 1);\n652\t  assert_true_expr(stats.ac_match_list_length_pctls[1] == 1);\n653\t  assert_true_expr(stats.ac_match_list_length_pctls[100] == 1);\n654\t\n655\t  stats_for_rules(\"\\\n656\t      rule test { \\\n657\t      strings: \\\n658\t        $ = \\\"abcd0\\\" \\\n659\t        $ = \\\"abcd1\\\" \\\n660\t        $ = \\\"abcd2\\\" \\\n661\t        $ = \\\"efgh0\\\" \\\n662\t        $ = \\\"efgh1\\\" \\\n663\t        $ = \\\"efgh2\\\" \\\n664\t      condition: all of them }\",\n665\t      &stats);\n666\t\n667\t  assert_true_expr(stats.rules == 1);\n668\t  assert_true_expr(stats.strings == 6);\n669\t  assert_true_expr(stats.ac_matches == 6);\n670\t  assert_true_expr(stats.ac_root_match_list_length == 0);\n671\t  assert_true_expr(stats.top_ac_match_list_lengths[0] == 3);\n672\t  assert_true_expr(stats.ac_match_list_length_pctls[1] == 3);\n673\t  assert_true_expr(stats.ac_match_list_length_pctls[100] == 3);\n674\t\n675\t  stats_for_rules(\"\\\n676\t      rule test { \\\n677\t      strings: \\\n678\t        $ = \\\"abcd0\\\" \\\n679\t        $ = \\\"abcd1\\\" \\\n680\t        $ = \\\"abcd2\\\" \\\n681\t        $ = \\\"efgh0\\\" \\\n682\t        $ = \\\"ijkl0\\\" \\\n683\t        $ = \\\"mnop0\\\" \\\n684\t        $ = \\\"mnop1\\\" \\\n685\t        $ = \\\"qrst0\\\" \\\n686\t      condition: all of them }\",\n687\t      &stats);\n688\t\n689\t  assert_true_expr(stats.rules == 1);\n690\t  assert_true_expr(stats.strings == 8);\n691\t  assert_true_expr(stats.ac_matches == 8);\n692\t  assert_true_expr(stats.ac_root_match_list_length == 0);\n693\t  assert_true_expr(stats.top_ac_match_list_lengths[0] == 3);\n694\t  assert_true_expr(stats.ac_match_list_length_pctls[1] == 1);\n695\t  assert_true_expr(stats.ac_match_list_length_pctls[100] == 3);\n696\t}\n697\t\n698\t\n699\tvoid test_issue_920()\n700\t{\n701\t  const char* rules_str = \"\\\n702\t      rule test { \\\n703\t        condition: true \\\n704\t      }\";\n705\t\n706\t  YR_COMPILER* compiler = NULL;\n707\t\n708\t  yr_initialize();\n709\t\n710\t  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n711\t  {\n712\t    perror(\"yr_compiler_create\");\n713\t    exit(EXIT_FAILURE);\n714\t  }\n715\t\n716\t  // Define a variable named \"test\"\n717\t  yr_compiler_define_boolean_variable(compiler, \"test\", 1);\n718\t\n719\t  // The compilation should not succeed, as the rule is named \"test\" and a\n720\t  // a variable with the same name already exists.\n721\t  yr_compiler_add_string(compiler, rules_str, NULL);\n722\t\n723\t  if (compiler->last_error != ERROR_DUPLICATED_IDENTIFIER)\n724\t  {\n725\t    yr_compiler_destroy(compiler);\n726\t    printf(\"expecting ERROR_CALLBACK_REQUIRED (%d), got: %d\\n\",\n727\t           ERROR_DUPLICATED_IDENTIFIER, compiler->last_error);\n728\t    exit(EXIT_FAILURE);\n729\t  }\n730\t\n731\t  yr_compiler_destroy(compiler);\n732\t  yr_finalize();\n733\t}\n734\t\n735\tint main(int argc, char** argv)\n736\t{\n737\t  int index = defects4cpp_test_index();\n738\t  switch (index) {\n739\t      case 45:\n740\t  test_disabled_rules();\n741\t          break;\n742\t      case 46:\n743\t  test_file_descriptor();\n744\t          break;\n745\t      case 47:\n746\t  test_max_string_per_rules();\n747\t          break;\n748\t      case 48:\n749\t  test_max_match_data();\n750\t          break;\n751\t      case 49:\n752\t  test_include_callback();\n753\t          break;\n754\t      case 50:\n755\t  test_save_load_rules();\n756\t          break;\n757\t      case 51:\n758\t  test_scanner();\n759\t          break;\n760\t      case 52:\n761\t  test_ast_callback();\n762\t          break;\n763\t      case 53:\n764\t  test_rules_stats();\n765\t          break;\n766\t      case 54:\n767\t  test_issue_834();\n768\t          break;\n769\t      case 55:\n770\t  test_issue_920();\n771\t          break;\n772\t  }\n773\t}\n774\t"}]},"parent_tool_use_id":null,"session_id":"2e2d2940-6134-497c-8abb-dfacce545af5","uuid":"7fabb34f-66b9-405b-a66c-750c665befc4","timestamp":"2026-05-02T21:22:18.491Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ibraheemamin/projects/COS484/chatdbgpro/data/workspaces/yara-1/yara/buggy-1/tests/test-api.c","content":"\n#include <yara.h>\n#include \"util.h\"\n\n#if defined(_WIN32) || defined(__CYGWIN__)\n#include <fileapi.h>\n#else\n#include <unistd.h>\n#endif\n#include <fcntl.h>\n\n#include \"defects4cpp.h\"\n\nvoid test_disabled_rules()\n{\n  YR_RULES* rules;\n  YR_RULE* rule;\n\n  int matches = 0;\n  char* buf = \"foo bar\";\n  char* rules_str = \" \\\n    rule disabled_rule {condition: true} \\\n    rule false_rule {condition: true and disabled_rule} \\\n    rule true_rule {condition: true or disabled_rule}\";\n\n\n  yr_initialize();\n\n  if (compile_rule(rules_str, &rules) != ERROR_SUCCESS)\n  {\n    perror(\"compile_rule\");\n    exit(EXIT_FAILURE);\n  }\n\n  // diable any rule containing disable in its identifier\n  yr_rules_foreach(rules, rule)\n  {\n    if (strstr(rule->identifier, \"disabled\"))\n      yr_rule_disable(rule);\n  }\n\n  yr_rules_scan_mem(\n      rules, (uint8_t *) buf, strlen(buf), 0, count_matches, &matches, 0);\n\n  yr_rules_destroy(rules);\n\n  // matches should be exactly one.\n  if (matches != 1)\n  {\n    fprintf(stderr, \"test_disabled_rules failed\\n\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_finalize();\n}\n\n\nconst char* _include_callback(\n  const char* include_name,\n  const char* calling_rule_filename,\n  const char* calling_rule_namespace,\n  void* user_data)\n{\nif (strcmp(include_name, \"ok\") == 0)\n  return \"rule test {condition: true}\";\nelse\n  return NULL;\n}\n\n\nvoid test_include_callback()\n{\n  YR_COMPILER* compiler = NULL;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_set_include_callback(compiler, _include_callback, NULL, NULL);\n\n  // This include produces no error.\n  if (yr_compiler_add_string(compiler, \"include \\\"ok\\\"\", NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    exit(EXIT_FAILURE);\n  }\n\n  // This include one error.\n  if (yr_compiler_add_string(compiler, \"include \\\"fail\\\"\", NULL) != 1)\n  {\n    yr_compiler_destroy(compiler);\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n  yr_finalize();\n}\n\n\nvoid test_file_descriptor()\n{\n  YR_COMPILER* compiler = NULL;\n  YR_RULES* rules = NULL;\n\n#if defined(_WIN32) || defined(__CYGWIN__)\n  HANDLE fd = CreateFile(\"tests/data/baz.yar\", GENERIC_READ, 0, NULL, OPEN_EXISTING, 0, NULL);\n  if (fd == INVALID_HANDLE_VALUE)\n  {\n    fputs(\"CreateFile failed\", stderr);\n    exit(1);\n  }\n#else\n  int fd = open(\"tests/data/baz.yar\", O_RDONLY);\n  if (fd < 0)\n  {\n    perror(\"open\");\n    exit(EXIT_FAILURE);\n  }\n#endif\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_add_fd(compiler, fd, NULL, NULL) != 0)\n  {\n    perror(\"yr_compiler_add_fd\");\n    exit(EXIT_FAILURE);\n  }\n\n#if defined(_WIN32) || defined(__CYGWIN__)\n  CloseHandle(fd);\n#else\n  close(fd);\n#endif\n\n  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_add_fd\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (compiler)\n    yr_compiler_destroy(compiler);\n\n  if (rules)\n    yr_rules_destroy(rules);\n\n  yr_finalize();\n\n  return;\n}\n\nvoid test_max_string_per_rules()\n{\n  uint32_t new_max_strings_per_rule = 1;\n  uint32_t old_max_strings_per_rule;\n\n  yr_initialize();\n\n  yr_get_configuration(\n      YR_CONFIG_MAX_STRINGS_PER_RULE,\n      (void*) &old_max_strings_per_rule);\n\n  yr_set_configuration(\n      YR_CONFIG_MAX_STRINGS_PER_RULE,\n      (void*) &new_max_strings_per_rule);\n\n  assert_error(\n      \"rule test { \\\n         strings: \\\n           $ = \\\"uno\\\" \\\n           $ = \\\"dos\\\" \\\n         condition: \\\n           all of them }\",\n      ERROR_TOO_MANY_STRINGS);\n\n  new_max_strings_per_rule = 2;\n\n  yr_set_configuration(\n      YR_CONFIG_MAX_STRINGS_PER_RULE,\n      (void*) &new_max_strings_per_rule);\n\n  assert_error(\n      \"rule test { \\\n         strings: \\\n           $ = \\\"uno\\\" \\\n           $ = \\\"dos\\\" \\\n         condition: \\\n           all of them }\",\n      ERROR_SUCCESS);\n\n  yr_set_configuration(\n      YR_CONFIG_MAX_STRINGS_PER_RULE,\n      (void*) &old_max_strings_per_rule);\n\n  yr_finalize();\n}\n\n\nint test_max_match_data_callback(\n    int message,\n    void* message_data,\n    void* user_data)\n{\n  if (message == CALLBACK_MSG_RULE_MATCHING)\n  {\n    YR_RULE* r = (YR_RULE*) message_data;\n    YR_STRING* s;\n\n    yr_rule_strings_foreach(r, s)\n    {\n      YR_MATCH* m;\n\n      yr_string_matches_foreach(s, m)\n      {\n        if (m->data_length > 0)\n          return CALLBACK_ERROR;\n      }\n    }\n  }\n\n  return CALLBACK_CONTINUE;\n}\n\nvoid test_max_match_data()\n{\n  YR_RULES* rules;\n\n  uint32_t new_max_match_data = 0;\n  uint32_t old_max_match_data;\n\n  char* rules_str = \"rule t { strings: $a = \\\"foobar\\\" condition: $a }\";\n\n  yr_initialize();\n\n  yr_get_configuration(\n      YR_CONFIG_MAX_MATCH_DATA,\n      (void*) &old_max_match_data);\n\n  yr_set_configuration(\n      YR_CONFIG_MAX_MATCH_DATA,\n      (void*) &new_max_match_data);\n\n  if (compile_rule(rules_str, &rules) != ERROR_SUCCESS)\n  {\n    perror(\"compile_rule\");\n    exit(EXIT_FAILURE);\n  }\n\n  int err = yr_rules_scan_mem(\n      rules,\n      (const uint8_t *) \"foobar\",\n      6,\n      0,\n      test_max_match_data_callback,\n      NULL,\n      0);\n\n  if (err != ERROR_SUCCESS)\n  {\n    fprintf(stderr, \"test_max_match_data failed\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_rules_destroy(rules);\n  yr_finalize();\n}\n\n\nvoid test_save_load_rules()\n{\n  YR_COMPILER* compiler = NULL;\n  YR_RULES* rules = NULL;\n\n  int matches = 0;\n  char* rules_str = \"rule t {condition: bool_var and str_var == \\\"foobar\\\"}\";\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_define_boolean_variable(compiler, \"bool_var\", 1);\n  yr_compiler_define_string_variable(compiler, \"str_var\", \"foobar\");\n\n  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_string\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_fd\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n\n  if (yr_rules_save(rules, \"test-rules.yarc\") != ERROR_SUCCESS)\n  {\n    yr_rules_destroy(rules);\n    perror(\"yr_rules_save\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_rules_destroy(rules);\n\n  if (yr_rules_load(\"test-rules.yarc\", &rules) != ERROR_SUCCESS)\n  {\n    perror(\"yr_rules_load\");\n    exit(EXIT_FAILURE);\n  }\n\n  int err = yr_rules_scan_mem(\n      rules,\n      (uint8_t *) \"\",\n       0,\n       0,\n       count_matches,\n       &matches,\n       0);\n\n  if (err != ERROR_SUCCESS)\n  {\n    fprintf(stderr, \"test_save_load_rules: error: %d\\n\", err);\n    exit(EXIT_FAILURE);\n  }\n\n  if (matches != 1)\n  {\n    fprintf(stderr, \"test_save_load_rules: expecting 1 match, got: %d\\n\", matches);\n    exit(EXIT_FAILURE);\n  }\n\n  yr_rules_destroy(rules);\n  yr_finalize();\n}\n\n\nvoid test_scanner()\n{\n  int matches = 0;\n  const char* buf = \"dummy\";\n  const char* rules_str = \"\\\n    rule test { \\\n    condition: bool_var and int_var == 1 and str_var == \\\"foo\\\" }\";\n\n  YR_COMPILER* compiler = NULL;\n  YR_RULES* rules = NULL;\n  YR_SCANNER* scanner1 = NULL;\n  YR_SCANNER* scanner2 = NULL;\n\n  int result;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  // Define a few variables\n  yr_compiler_define_integer_variable(compiler, \"int_var\", 0);\n  yr_compiler_define_boolean_variable(compiler, \"bool_var\", 0);\n  yr_compiler_define_string_variable(compiler, \"str_var\", \"\");\n\n\n  if (yr_compiler_define_string_variable(\n      compiler, \"str_var\", \"\") != ERROR_DUPLICATED_EXTERNAL_VARIABLE)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"expecting ERROR_DUPLICATED_EXTERNAL_VARIABLE\");\n    exit(EXIT_FAILURE);\n  }\n\n  // Compile a rule that use the variables in the condition.\n  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_string\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_get_rules\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n\n  // Create an scanner\n  if (yr_scanner_create(rules, &scanner1)!= ERROR_SUCCESS)\n  {\n    yr_rules_destroy(rules);\n    perror(\"yr_scanner_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  // Create another scanner\n  if (yr_scanner_create(rules, &scanner2)!= ERROR_SUCCESS)\n  {\n    yr_scanner_destroy(scanner1);\n    yr_rules_destroy(rules);\n    perror(\"yr_scanner_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  // Let's check the yr_scanner_scan_mem returns the appropriate error when\n  // called without specifying a callback.\n  result = yr_scanner_scan_mem(scanner1, (uint8_t *) buf, strlen(buf));\n\n  if (result != ERROR_CALLBACK_REQUIRED)\n  {\n    yr_scanner_destroy(scanner1);\n    yr_scanner_destroy(scanner2);\n    yr_rules_destroy(rules);\n    printf(\"expecting ERROR_CALLBACK_REQUIRED (%d), got: %d\\n\",\n           ERROR_CALLBACK_REQUIRED, result);\n    exit(EXIT_FAILURE);\n  }\n\n  // Set the callback and a some the correct values for the rule to match.\n  yr_scanner_set_callback(scanner1, count_matches, &matches);\n  yr_scanner_define_integer_variable(scanner1, \"int_var\", 1);\n  yr_scanner_define_boolean_variable(scanner1, \"bool_var\", 1);\n  yr_scanner_define_string_variable(scanner1, \"str_var\", \"foo\");\n\n  // Set some other values for the second scanner to make sure it doesn't\n  // interfere with the first one.\n  yr_scanner_define_integer_variable(scanner2, \"int_var\", 2);\n  yr_scanner_define_boolean_variable(scanner2, \"bool_var\", 0);\n  yr_scanner_define_string_variable(scanner2, \"str_var\", \"bar\");\n\n  result = yr_scanner_scan_mem(scanner1, (uint8_t *) buf, strlen(buf));\n\n  if (result != ERROR_SUCCESS)\n  {\n    yr_scanner_destroy(scanner1);\n    yr_scanner_destroy(scanner2);\n    yr_rules_destroy(rules);\n    printf(\"expecting ERROR_SUCCESS (%d), got: %d\\n\",\n           ERROR_SUCCESS, result);\n    exit(EXIT_FAILURE);\n  }\n\n  if (matches != 1)\n  {\n    yr_scanner_destroy(scanner1);\n    yr_scanner_destroy(scanner2);\n    yr_rules_destroy(rules);\n    exit(EXIT_FAILURE);\n  }\n\n  yr_scanner_destroy(scanner1);\n  yr_scanner_destroy(scanner2);\n  yr_rules_destroy(rules);\n  yr_finalize();\n}\n\n// Test case for https://github.com/VirusTotal/yara/issues/834. Use the same\n// scanner for scanning multiple files with a rule that imports the \"tests\"\n// module. If the unload_module function is called twice an assertion is\n// triggered by the module.\nvoid test_issue_834()\n{\n  const char* buf = \"dummy\";\n  const char* rules_str = \"import \\\"tests\\\" rule test { condition: true }\";\n\n  YR_COMPILER* compiler = NULL;\n  YR_RULES* rules = NULL;\n  YR_SCANNER* scanner = NULL;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_string\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_get_rules\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n\n  if (yr_scanner_create(rules, &scanner)!= ERROR_SUCCESS)\n  {\n    yr_rules_destroy(rules);\n    perror(\"yr_scanner_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_scanner_set_callback(scanner, do_nothing, NULL);\n\n  // Call yr_scanner_scan_mem twice.\n  yr_scanner_scan_mem(scanner, (uint8_t *) buf, strlen(buf));\n  yr_scanner_scan_mem(scanner, (uint8_t *) buf, strlen(buf));\n\n  yr_scanner_destroy(scanner);\n  yr_rules_destroy(rules);\n  yr_finalize();\n}\n\n\nvoid ast_callback(\n    const YR_RULE* rule,\n    const char* string_identifier,\n    const RE_AST* re_ast,\n    void* user_data)\n{\n  if (strcmp(rule->identifier, \"test\") == 0 &&\n      strcmp(string_identifier, \"$foo\") == 0)\n  {\n    *((int*) user_data) = 1;\n  }\n}\n\nvoid test_ast_callback()\n{\n  const char* rules_str = \"\\\n      rule test { \\\n      strings: $foo = /a.*b/ \\\n      condition: $foo }\";\n\n  YR_COMPILER* compiler = NULL;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  int ok = 0;\n\n  yr_compiler_set_re_ast_callback(\n      compiler,\n      ast_callback,\n      &ok);\n\n  // Compile a rule that use the variables in the condition.\n  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_string\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (!ok)\n  {\n    printf(\"ast callback failed\\n\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n  yr_finalize();\n}\n\n\nvoid stats_for_rules(\n    const char* rules_str,\n    YR_RULES_STATS* stats)\n{\n  YR_COMPILER* compiler = NULL;\n  YR_RULES* rules = NULL;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_add_string(compiler, rules_str, NULL) != 0)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_add_string\");\n    exit(EXIT_FAILURE);\n  }\n\n  if (yr_compiler_get_rules(compiler, &rules) != ERROR_SUCCESS)\n  {\n    yr_compiler_destroy(compiler);\n    perror(\"yr_compiler_get_rules\");\n    exit(EXIT_FAILURE);\n  }\n\n  yr_rules_get_stats(rules, stats);\n\n  yr_compiler_destroy(compiler);\n  yr_rules_destroy(rules);\n  yr_finalize();\n}\n\n\nvoid test_rules_stats()\n{\n  YR_RULES_STATS stats;\n\n  stats_for_rules(\"\\\n      rule test { \\\n      strings: $ = /.*/ \\\n      condition: all of them }\",\n      &stats);\n\n  assert_true_expr(stats.rules == 1);\n  assert_true_expr(stats.strings == 1);\n  assert_true_expr(stats.ac_root_match_list_length == 1);\n\n  stats_for_rules(\"\\\n      rule test { \\\n      strings: $ = \\\"abc\\\" \\\n      condition: all of them }\",\n      &stats);\n\n  assert_true_expr(stats.rules == 1);\n  assert_true_expr(stats.strings == 1);\n  assert_true_expr(stats.ac_matches == 1);\n  assert_true_expr(stats.ac_root_match_list_length == 0);\n  assert_true_expr(stats.top_ac_match_list_lengths[0] == 1);\n  assert_true_expr(stats.ac_match_list_length_pctls[1] == 1);\n  assert_true_expr(stats.ac_match_list_length_pctls[100] == 1);\n\n  stats_for_rules(\"\\\n      rule test { \\\n      strings: \\\n        $ = \\\"abcd0\\\" \\\n        $ = \\\"abcd1\\\" \\\n        $ = \\\"abcd2\\\" \\\n        $ = \\\"efgh0\\\" \\\n        $ = \\\"efgh1\\\" \\\n        $ = \\\"efgh2\\\" \\\n      condition: all of them }\",\n      &stats);\n\n  assert_true_expr(stats.rules == 1);\n  assert_true_expr(stats.strings == 6);\n  assert_true_expr(stats.ac_matches == 6);\n  assert_true_expr(stats.ac_root_match_list_length == 0);\n  assert_true_expr(stats.top_ac_match_list_lengths[0] == 3);\n  assert_true_expr(stats.ac_match_list_length_pctls[1] == 3);\n  assert_true_expr(stats.ac_match_list_length_pctls[100] == 3);\n\n  stats_for_rules(\"\\\n      rule test { \\\n      strings: \\\n        $ = \\\"abcd0\\\" \\\n        $ = \\\"abcd1\\\" \\\n        $ = \\\"abcd2\\\" \\\n        $ = \\\"efgh0\\\" \\\n        $ = \\\"ijkl0\\\" \\\n        $ = \\\"mnop0\\\" \\\n        $ = \\\"mnop1\\\" \\\n        $ = \\\"qrst0\\\" \\\n      condition: all of them }\",\n      &stats);\n\n  assert_true_expr(stats.rules == 1);\n  assert_true_expr(stats.strings == 8);\n  assert_true_expr(stats.ac_matches == 8);\n  assert_true_expr(stats.ac_root_match_list_length == 0);\n  assert_true_expr(stats.top_ac_match_list_lengths[0] == 3);\n  assert_true_expr(stats.ac_match_list_length_pctls[1] == 1);\n  assert_true_expr(stats.ac_match_list_length_pctls[100] == 3);\n}\n\n\nvoid test_issue_920()\n{\n  const char* rules_str = \"\\\n      rule test { \\\n        condition: true \\\n      }\";\n\n  YR_COMPILER* compiler = NULL;\n\n  yr_initialize();\n\n  if (yr_compiler_create(&compiler) != ERROR_SUCCESS)\n  {\n    perror(\"yr_compiler_create\");\n    exit(EXIT_FAILURE);\n  }\n\n  // Define a variable named \"test\"\n  yr_compiler_define_boolean_variable(compiler, \"test\", 1);\n\n  // The compilation should not succeed, as the rule is named \"test\" and a\n  // a variable with the same name already exists.\n  yr_compiler_add_string(compiler, rules_str, NULL);\n\n  if (compiler->last_error != ERROR_DUPLICATED_IDENTIFIER)\n  {\n    yr_compiler_destroy(compiler);\n    printf(\"expecting ERROR_CALLBACK_REQUIRED (%d), got: %d\\n\",\n           ERROR_DUPLICATED_IDENTIFIER, compiler->last_error);\n    exit(EXIT_FAILURE);\n  }\n\n  yr_compiler_destroy(compiler);\n  yr_finalize();\n}\n\nint main(int argc, char** argv)\n{\n  int index = defects4cpp_test_index();\n  switch (index) {\n      case 45:\n  test_disabled_rules();\n          break;\n      case 46:\n  test_file_descriptor();\n          break;\n      case 47:\n  test_max_string_per_rules();\n          break;\n      case 48:\n  test_max_match_data();\n          break;\n      case 49:\n  test_include_callback();\n          break;\n      case 50:\n  test_save_load_rules();\n          break;\n      case 51:\n  test_scanner();\n          break;\n      case 52:\n  test_ast_callback();\n          break;\n      case 53:\n  test_rules_stats();\n          break;\n      case 54:\n  test_issue_834();\n          break;\n      case 55:\n  test_issue_920();\n          break;\n  }\n}\n","numLines":774,"startLine":1,"totalLines":774}}}
