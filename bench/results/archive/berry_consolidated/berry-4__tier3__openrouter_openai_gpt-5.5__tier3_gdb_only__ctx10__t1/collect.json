        "p = get_mode(p + 1, mode);\nbuf[0] = '\\0';\nif (index > top) {\n    be_raise(vm, \"runtime_error\", be_pushfstring(vm,\n        \"bad argument #%d to 'format': no value\", index));\n}\nswitch (*p) {\n...",
        "default:\n    be_raise(vm, \"runtime_error\", be_pushfstring(vm,\n        \"invalid option '%%%c' to 'format'\", *p));",
        "diff --git a/src/be_strlib.c b/src/be_strlib.c\nindex ... .. ...\n--- a/src/be_strlib.c\n+++ b/src/be_strlib.c\n@@ -511,8 +511,15 @@ static int str_format(bvm *vm)\n             pushstr(vm, format, p - format);\n             concat2(vm);\n             p = get_mode(p + 1, mode);\n             buf[0] = '\\0';\n+\n+            /* \"%%\" is an escaped percent.  It does not consume an argument. */\n+            if (*p == '%') {\n+                pushstr(vm, \"%\", 1);\n+                concat2(vm);\n+                format = p + 1;\n+                continue;\n+            }\n+\n             if (index > top) {\n                 be_raise(vm, \"runtime_error\", be_pushfstring(vm,\n                     \"bad argument #%d to 'format': no value\", index));\n             }\n             switch (*p) {",
        "s.format(\"%%\")          // \"%\"\ns.format(\"%i%%\", 12)    // \"12%\"\ns.format(\"%i%%%i\", 12, 13) // \"12%13\"\ns.format(\"%s%%\", \"foo\") // \"foo%\"",
        "@@ -511,8 +511,15 @@ static int str_format(bvm *vm)\n             pushstr(vm, format, p - format);\n             concat2(vm);\n             p = get_mode(p + 1, mode);\n             buf[0] = '\\0';\n+            if (*p == '%') {\n+                pushstr(vm, \"%\", 1);\n+                concat2(vm);\n+                format = p + 1;\n+                continue;\n+            }\n             if (index > top) {\n                 be_raise(vm, \"runtime_error\", be_pushfstring(vm,\n                     \"bad argument #%d to 'format': no value\", index));\n             }"
