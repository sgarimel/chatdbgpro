    The crash is caused by an off-by-one heap allocation bug in first_field().  
                                                                                
    At the crashing line:                                                       
                                                                                
                                                                                
     out[n] = '\0';                                                             
                                                                                
                                                                                
    the program writes one byte past the end of the heap allocation.            
                                                                                
    Walkthrough of the program state                                            
                                                                                
    main() sets:                                                                
                                                                                
                                                                                
     const char *line = "alice,bob,carol\n";                                    
     char *first = first_field(line);                                           
                                                                                
                                                                                
    So inside first_field():                                                    
                                                                                
                                                                                
     static char *first_field(const char *line) {                               
                                                                                
                                                                                
    line points to the string literal:                                          
                                                                                
                                                                                
     "alice,bob,carol\n"                                                        
                                                                                
                                                                                
    The characters are:                                                         
                                                                                
                                                                                
     index:  0 1 2 3 4 5 ...                                                    
     char:   a l i c e , ...                                                    
                                                                                
                                                                                
    Then:                                                                       
                                                                                
                                                                                
     const char *comma = strchr(line, ',');                                     
                                                                                
                                                                                
    strchr() finds the first comma, which is at line + 5.                       
                                                                                
    So:                                                                         
                                                                                
                                                                                
     comma == line + 5                                                          
                                                                                
                                                                                
    Next:                                                                       
                                                                                
                                                                                
     size_t n = comma ? (size_t)(comma - line) : strlen(line);                  
                                                                                
                                                                                
    Because comma is non-NULL:                                                  
                                                                                
                                                                                
     n = comma - line;                                                          
     n = 5;                                                                     
                                                                                
                                                                                
    This means the first field has length 5: "alice".                           
                                                                                
    Then the code allocates:                                                    
                                                                                
                                                                                
     char *out = (char *)malloc(n);                                             
                                                                                
                                                                                
    Since n == 5, this allocates exactly 5 bytes.                               
                                                                                
    Valid indexes in out are therefore:                                         
                                                                                
                                                                                
     out[0], out[1], out[2], out[3], out[4]                                     
                                                                                
                                                                                
    Then:                                                                       
                                                                                
                                                                                
     memcpy(out, line, n);                                                      
                                                                                
                                                                                
    This copies 5 bytes:                                                        
                                                                                
                                                                                
     'a', 'l', 'i', 'c', 'e'                                                    
                                                                                
                                                                                
    That part is valid because it writes exactly 5 bytes into a 5-byte          
    allocation.                                                                 
                                                                                
    But then:                                                                   
                                                                                
                                                                                
     out[n] = '\0';                                                             
                                                                                
                                                                                
    Since n == 5, this writes:                                                  
                                                                                
                                                                                
     out[5] = '\0';                                                             
                                                                                
                                                                                
    That is one byte past the allocated buffer. The allocation only has         
    indexes 0 through 4.                                                        
                                                                                
    So AddressSanitizer reports:                                                
                                                                                
                                                                                
     Heap buffer overflow                                                       
                                                                                
                                                                                
    The defect is here:                                                         
                                                                                
                                                                                
     char *out = (char *)malloc(n);                                             
                                                                                
                                                                                
    The function is trying to return a C string, but a C string needs space     
    for both the characters and the terminating null byte. The allocation       
    needs to be n + 1 bytes, not n bytes.                                       
                                                                                
    This bug is not specific to the input "alice,bob,carol\n". It also happens  
    when there is no comma:                                                     
                                                                                
                                                                                
     size_t n = strlen(line);                                                   
     char *out = malloc(n);                                                     
     memcpy(out, line, n);                                                      
     out[n] = '\0';   // still one byte past the allocation                     
                                                                                
                                                                                
    It can also be especially problematic for an empty field, e.g. ",bob":      
                                                                                
                                                                                
     n = 0;                                                                     
     out = malloc(0);                                                           
     out[0] = '\0';   // invalid because no byte was allocated                  
                                                                                
                                                                                
    Recommendation                                                              
                                                                                
    Minimal local fix:                                                          
                                                                                
                                                                                
     static char *first_field(const char *line) {                               
         const char *comma = strchr(line, ',');                                 
         size_t n = comma ? (size_t)(comma - line) : strlen(line);              
                                                                                
         char *out = malloc(n + 1);                                             
         if (!out) {                                                            
             return NULL;                                                       
         }                                                                      
                                                                                
         memcpy(out, line, n);                                                  
         out[n] = '\0';                                                         
                                                                                
         return out;                                                            
     }                                                                          
                                                                                
                                                                                
    More thorough root-cause fix, including overflow and NULL-input handling:   
                                                                                
                                                                                
     #include <stdio.h>                                                         
     #include <stdlib.h>                                                        
     #include <string.h>                                                        
     #include <stdint.h>                                                        
                                                                                
     static char *first_field(const char *line) {                               
         if (line == NULL) {                                                    
             return NULL;                                                       
         }                                                                      
                                                                                
         const char *comma = strchr(line, ',');                                 
         size_t n = comma ? (size_t)(comma - line) : strlen(line);              
                                                                                
         if (n == SIZE_MAX) {                                                   
             return NULL; // prevent overflow in n + 1                          
         }                                                                      
                                                                                
         char *out = malloc(n + 1);                                             
         if (out == NULL) {                                                     
             return NULL;                                                       
         }                                                                      
                                                                                
         memcpy(out, line, n);                                                  
         out[n] = '\0';                                                         
                                                                                
         return out;                                                            
     }                                                                          
                                                                                
     int main(void) {                                                           
         const char *line = "alice,bob,carol\n";                                
         char *first = first_field(line);                                       
                                                                                
         if (first == NULL) {                                                   
             fprintf(stderr, "failed to parse first field\n");                  
             return 1;                                                          
         }                                                                      
                                                                                
         printf("first = %s\n", first);                                         
         free(first);                                                           
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    The essential fix is to allocate n + 1 bytes because the returned buffer    
    is a null-terminated string.                                                
                                                                                
