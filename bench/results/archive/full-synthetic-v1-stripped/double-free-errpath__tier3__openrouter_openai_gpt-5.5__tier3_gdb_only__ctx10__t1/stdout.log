    The crash is caused by a double free of b->name.                            
                                                                                
    At the point of the crash:                                                  
                                                                                
                                                                                
     static void destroy_blob(blob_t *b) {                                      
         if (!b) return;                                                        
         free(b->name);          /* crash: b->name was already freed */         
         free(b);                                                               
     }                                                                          
                                                                                
                                                                                
    b itself is still a valid allocated blob_t, but its name field points to    
    memory that was already freed earlier in load_blob().                       
                                                                                
    Walkthrough:                                                                
                                                                                
                                                                                
     int main(void) {                                                           
         blob_t *b = load_blob("abcdef");                                       
                                                                                
                                                                                
    main() calls:                                                               
                                                                                
                                                                                
     load_blob("abcdef")                                                        
                                                                                
                                                                                
    Inside load_blob():                                                         
                                                                                
                                                                                
     blob_t *b = (blob_t *)malloc(sizeof(*b));                                  
                                                                                
                                                                                
    A blob_t is allocated. So now:                                              
                                                                                
                                                                                
     b != NULL                                                                  
                                                                                
                                                                                
    Then:                                                                       
                                                                                
                                                                                
     b->name = strdup(name);                                                    
     b->size = 0;                                                               
                                                                                
                                                                                
    Because name is "abcdef", strdup() allocates a new heap buffer containing   
    "abcdef" and stores its address in b->name.                                 
                                                                                
    So the state is approximately:                                              
                                                                                
                                                                                
     b = 0x6020000000d0                                                         
     b->name = <heap pointer to "abcdef">                                       
     b->size = 0                                                                
                                                                                
                                                                                
    Then this branch is taken:                                                  
                                                                                
                                                                                
     if (strlen(name) > 4) {                                                    
         free(b->name);      /* release the name on the recoverable error       
     path */                                                                    
         b->size = 0;                                                           
         return b;           /* hand the partially-initialised blob back */     
     }                                                                          
                                                                                
                                                                                
    Because:                                                                    
                                                                                
                                                                                
     strlen("abcdef") == 6                                                      
                                                                                
                                                                                
    and 6 > 4, the recoverable error path runs.                                 
                                                                                
    The important defect is here:                                               
                                                                                
                                                                                
     free(b->name);                                                             
                                                                                
                                                                                
    After this call, the heap allocation owned by b->name is released.          
    However, b->name is not changed. It still contains the old pointer value,   
    but that pointer is now dangling.                                           
                                                                                
    So after load_blob() returns, the state is:                                 
                                                                                
                                                                                
     b != NULL                                                                  
     b->size == 0                                                               
     b->name == <dangling pointer to already-freed memory>                      
                                                                                
                                                                                
    Then main() does:                                                           
                                                                                
                                                                                
     if (b && b->size == 0) {                                                   
         fprintf(stderr, "load_blob: empty blob, cleaning up\n");               
     }                                                                          
                                                                                
                                                                                
    This condition is true because b is non-null and b->size is 0. But this     
    block only prints a message; it does not repair or clear b->name.           
                                                                                
    Then:                                                                       
                                                                                
                                                                                
     destroy_blob(b);                                                           
                                                                                
                                                                                
    Inside destroy_blob():                                                      
                                                                                
                                                                                
     free(b->name);                                                             
                                                                                
                                                                                
    This attempts to free the same allocation that was already freed in         
    load_blob().                                                                
                                                                                
    That is why AddressSanitizer reports:                                       
                                                                                
                                                                                
     Deallocation of freed memory                                               
                                                                                
                                                                                
    The root cause is that load_blob() returns a blob_t whose destructor is     
    expected to own and free b->name, but load_blob() has already freed         
    b->name and left the pointer dangling.                                      
                                                                                
    There is an ownership invariant violation:                                  
                                                                                
                                                                                
     destroy_blob()` assumes:                                                   
         if b->name is non-NULL, it points to live heap memory owned by b.      
                                                                                
     load_blob()` violates that by returning:                                   
         b->name points to already-freed heap memory.                           
                                                                                
                                                                                
    A freed pointer must not remain in an object that will later be passed to   
    a destructor that frees that field.                                         
                                                                                
    Recommendation                                                              
                                                                                
    Minimal local fix: after freeing b->name in the recoverable error path,     
    set it to NULL.                                                             
                                                                                
                                                                                
     static blob_t *load_blob(const char *name) {                               
         blob_t *b = malloc(sizeof(*b));                                        
         if (!b) return NULL;                                                   
                                                                                
         b->name = strdup(name);                                                
         b->size = 0;                                                           
                                                                                
         if (!b->name) {                                                        
             free(b);                                                           
             return NULL;                                                       
         }                                                                      
                                                                                
         /* Simulated recoverable parse error. */                               
         if (strlen(name) > 4) {                                                
             free(b->name);                                                     
             b->name = NULL;      /* important: prevent later double free */    
             b->size = 0;                                                       
             return b;                                                          
         }                                                                      
                                                                                
         b->size = strlen(b->name);                                             
         return b;                                                              
     }                                                                          
                                                                                
                                                                                
    With this fix, destroy_blob() remains safe because:                         
                                                                                
                                                                                
     free(NULL);                                                                
                                                                                
                                                                                
    is a no-op in C.                                                            
                                                                                
    A more thorough root-cause fix is to make the ownership contract            
    consistent. Either return a fully valid object whose destructor owns all    
    fields, or return NULL/an error on failure.                                 
                                                                                
    For example, if the caller should receive an “empty blob”, then return a    
    valid empty blob with no owned name:                                        
                                                                                
                                                                                
     static blob_t *load_blob(const char *name) {                               
         blob_t *b = malloc(sizeof(*b));                                        
         if (!b) return NULL;                                                   
                                                                                
         b->name = strdup(name);                                                
         b->size = 0;                                                           
                                                                                
         if (!b->name) {                                                        
             free(b);                                                           
             return NULL;                                                       
         }                                                                      
                                                                                
         if (strlen(name) > 4) {                                                
             free(b->name);                                                     
             b->name = NULL;                                                    
             b->size = 0;                                                       
             return b;                                                          
         }                                                                      
                                                                                
         b->size = strlen(b->name);                                             
         return b;                                                              
     }                                                                          
                                                                                
                                                                                
    Alternatively, if a parse error means the blob should not be returned at    
    all, clean up completely and return NULL:                                   
                                                                                
                                                                                
     static blob_t *load_blob(const char *name) {                               
         blob_t *b = malloc(sizeof(*b));                                        
         if (!b) return NULL;                                                   
                                                                                
         b->name = strdup(name);                                                
         b->size = 0;                                                           
                                                                                
         if (!b->name) {                                                        
             free(b);                                                           
             return NULL;                                                       
         }                                                                      
                                                                                
         if (strlen(name) > 4) {                                                
             free(b->name);                                                     
             free(b);                                                           
             return NULL;                                                       
         }                                                                      
                                                                                
         b->size = strlen(b->name);                                             
         return b;                                                              
     }                                                                          
                                                                                
                                                                                
    Then main() can handle that cleanly:                                        
                                                                                
                                                                                
     int main(void) {                                                           
         blob_t *b = load_blob("abcdef");                                       
                                                                                
         if (!b) {                                                              
             fprintf(stderr, "load_blob failed\n");                             
             return 1;                                                          
         }                                                                      
                                                                                
         if (b->size == 0) {                                                    
             fprintf(stderr, "load_blob: empty blob, cleaning up\n");           
         }                                                                      
                                                                                
         destroy_blob(b);                                                       
         printf("done\n");                                                      
         return 0;                                                              
     }                                                                          
                                                                                
                                                                                
    The key rule is: if destroy_blob() is responsible for freeing b->name,      
    then load_blob() must not return a blob_t containing a dangling name        
    pointer. Either leave ownership to the destructor, or clear the pointer     
    after freeing it.                                                           
                                                                                
