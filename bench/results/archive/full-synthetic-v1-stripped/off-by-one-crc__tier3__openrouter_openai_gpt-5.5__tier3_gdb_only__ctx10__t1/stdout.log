    The crash is caused by an off-by-one read in crc8.                          
                                                                                
    At the time of the crash:                                                   
                                                                                
                                                                                
     uint8_t buf[7] = {0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07};               
     uint8_t c = crc8(buf, sizeof(buf));                                        
                                                                                
                                                                                
    buf is a stack array with exactly 7 bytes. Its valid indices are:           
                                                                                
                                                                                
     buf[0] through buf[6]                                                      
                                                                                
                                                                                
    sizeof(buf) is 7, so main calls:                                            
                                                                                
                                                                                
     crc8(buf, 7);                                                              
                                                                                
                                                                                
    Inside crc8:                                                                
                                                                                
                                                                                
     static uint8_t crc8(const uint8_t *buf, size_t len) {                      
         uint8_t crc = 0x00;                                                    
                                                                                
         for (size_t i = 0; i <= len; i++) {                                    
             crc ^= buf[i];                                                     
             ...                                                                
         }                                                                      
                                                                                
         return crc;                                                            
     }                                                                          
                                                                                
                                                                                
    The loop condition is:                                                      
                                                                                
                                                                                
     i <= len                                                                   
                                                                                
                                                                                
    Since len == 7, the loop runs for:                                          
                                                                                
                                                                                
     i = 0, 1, 2, 3, 4, 5, 6, 7                                                 
                                                                                
                                                                                
    The first seven iterations are valid:                                       
                                                                                
                                                                                
     buf[0] ... buf[6]                                                          
                                                                                
                                                                                
    But the final iteration tries to read:                                      
                                                                                
                                                                                
     buf[7]                                                                     
                                                                                
                                                                                
    That is one byte past the end of the stack array. AddressSanitizer reports  
    this as a stack buffer overflow at:                                         
                                                                                
                                                                                
     crc ^= buf[i];                                                             
                                                                                
                                                                                
    because it is reading one byte beyond the valid bounds of buf.              
                                                                                
    The important variable values are:                                          
                                                                                
                                                                                
     buf = stack array of 7 uint8_t values                                      
     sizeof(buf) = 7                                                            
     len = 7                                                                    
     i = 7 at the crashing iteration                                            
     buf[i] = buf[7], invalid out-of-bounds read                                
                                                                                
                                                                                
    The root cause is that len is being treated inconsistently. The caller      
    passes len as a byte count, but the loop treats it like the last valid      
    index by using <=.                                                          
                                                                                
    A length/count of 7 means there are 7 elements, indexed 0 through 6.        
    Therefore the loop must use < len, not <= len.                              
                                                                                
    Minimal local fix:                                                          
                                                                                
                                                                                
     static uint8_t crc8(const uint8_t *buf, size_t len) {                      
         uint8_t crc = 0x00;                                                    
                                                                                
         for (size_t i = 0; i < len; i++) {                                     
             crc ^= buf[i];                                                     
             for (int b = 0; b < 8; b++) {                                      
                 crc = (crc & 0x80)                                             
                     ? (uint8_t)((crc << 1) ^ 0x07)                             
                     : (uint8_t)(crc << 1);                                     
             }                                                                  
         }                                                                      
                                                                                
         return crc;                                                            
     }                                                                          
                                                                                
                                                                                
    With that change, crc8(buf, sizeof(buf)) processes exactly buf[0] through   
    buf[6].                                                                     
                                                                                
    A more thorough root-cause fix is to make the API contract explicit: len    
    should mean “number of bytes to process”, not “last valid index”. Rename    
    it if helpful and guard against invalid input:                              
                                                                                
                                                                                
     #include <stddef.h>                                                        
     #include <stdint.h>                                                        
                                                                                
     static uint8_t crc8(const uint8_t *buf, size_t nbytes) {                   
         uint8_t crc = 0x00;                                                    
                                                                                
         if (buf == NULL && nbytes != 0) {                                      
             return 0; // or handle error differently                           
         }                                                                      
                                                                                
         for (size_t i = 0; i < nbytes; i++) {                                  
             crc ^= buf[i];                                                     
                                                                                
             for (int b = 0; b < 8; b++) {                                      
                 if (crc & 0x80) {                                              
                     crc = (uint8_t)((crc << 1) ^ 0x07);                        
                 } else {                                                       
                     crc = (uint8_t)(crc << 1);                                 
                 }                                                              
             }                                                                  
         }                                                                      
                                                                                
         return crc;                                                            
     }                                                                          
                                                                                
     int main(void) {                                                           
