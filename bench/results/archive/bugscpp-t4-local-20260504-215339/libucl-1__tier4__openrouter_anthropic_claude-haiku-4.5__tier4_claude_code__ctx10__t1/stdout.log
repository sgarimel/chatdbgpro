 (1, sizeof (struct ucl_stack));\n741\t\n742\t\t\t\tif (parser->stack == NULL) {\n743\t\t\t\t\tucl_create_err (&parser->err, \"no memory\");\n744\t\t\t\t\treturn NULL;\n745\t\t\t\t}\n746\t\t\t}\n747\t\t\telse {\n748\t\t\t\tstack = calloc (1, sizeof (struct ucl_stack));\n749\t\n750\t\t\t\tif (stack == NULL) {\n751\t\t\t\t\tucl_create_err (&parser->err, \"no memory\");\n752\t\t\t\t\treturn NULL;\n753\t\t\t\t}\n754\t\n755\t\t\t\tstack->next = parser->stack;\n756\t\t\t\tparser->stack = stack;\n757\t\t\t}\n758\t\n759\t\t\tparser->stack->level = len | MSGPACK_CONTAINER_BIT;\n760\t\n761\t\t}\n762\t\telse {\n763\t\t\t/*\n764\t\t\t * Get the current stack top\n765\t\t\t */\n766\t\t\tif (parser->stack) {\n767\t\t\t\treturn parser->stack;\n768\t\t\t}\n769\t\t\telse {\n770\t\t\t\tucl_create_err (&parser->err, \"bad top level object for msgpack\");\n771\t\t\t\treturn NULL;\n772\t\t\t}\n773\t\t}\n774\t\n775\t\treturn parser->stack;\n776\t}\n777\t\n778\tstatic bool\n779\tucl_msgpack_is_container_finished (struct ucl_stack *container)\n780\t{\n781\t\tuint64_t level;\n782\t\n783\t\tassert (container != NULL);\n784\t\n785\t\tif (container->level & MSGPACK_CONTAINER_BIT) {\n786\t\t\tlevel = container->level & ~MSGPACK_CONTAINER_BIT;\n787\t\n788\t\t\tif (level == 0) {\n789\t\t\t\treturn true;\n790\t\t\t}\n791\t\t}\n792\t\n793\t\treturn false;\n794\t}\n795\t\n796\tstatic bool\n797\tucl_msgpack_insert_object (struct ucl_parser *parser,\n798\t\t\tconst unsigned char *key,\n799\t\t\tsize_t keylen, ucl_object_t *obj)\n800\t{\n801\t\tuint64_t level;\n802\t\tstruct ucl_stack *container;\n803\t\n804\t\tcontainer = parser->stack;\n805\t\tassert (container != NULL);\n806\t\tassert (container->level > 0);\n807\t\tassert (obj != NULL);\n808\t\tassert (container->obj != NULL);\n809\t\n810\t\tif (container->obj->type == UCL_ARRAY) {\n811\t\t\tucl_array_append (container->obj, obj);\n812\t\t}\n813\t\telse if (container->obj->type == UCL_OBJECT) {\n814\t\t\tif (key == NULL || keylen == 0) {\n815\t\t\t