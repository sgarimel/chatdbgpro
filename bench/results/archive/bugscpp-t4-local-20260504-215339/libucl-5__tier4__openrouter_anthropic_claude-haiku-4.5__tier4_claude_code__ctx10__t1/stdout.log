n to that state first. The issue is that the error occurs in `ucl_parse_after_value` before the parser can reach the key-parsing logic where macros are recognized. The parser should transition to `UCL_STATE_KEY` after finishing a value, but it's encountering the `.` character and rejecting it as an invalid delimiter instead.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":840,"cache_read_input_tokens":94605,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":840},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"629f68e6-0fab-4be9-9319-4eb338eb9f36","uuid":"8690ea5b-d23f-4572-9ec0-d1d0128a26fc"}
