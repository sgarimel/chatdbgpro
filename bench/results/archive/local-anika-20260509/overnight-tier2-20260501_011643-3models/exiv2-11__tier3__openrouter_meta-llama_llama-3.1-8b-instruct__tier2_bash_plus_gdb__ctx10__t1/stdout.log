   {
           if (tiff->errorString() == "Invalid IFD marker")
           {
                   warning("Mini: Invalid IFD marker in file %s", tiff->filename());
                   return -1;
           }
           else
           {
                   warning("Mini: %s", tiff->errorString());
                   return -1;
           }
   }
   ```
   
   This fix adds a check to see if the error message is "Invalid IFD marker"
   before returning a warning message.
   
