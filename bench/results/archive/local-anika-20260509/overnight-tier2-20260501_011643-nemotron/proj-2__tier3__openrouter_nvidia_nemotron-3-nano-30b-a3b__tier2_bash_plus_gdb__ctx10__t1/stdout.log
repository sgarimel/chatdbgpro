   int main(int argc, char **argv) {
       char *arg, *pargv[MAX_PARGS];
       char **eargv = argv;
       FILE *fid;
       int pargc = 0, eargc = 0, mon = 0;
   
       if ( (emess_dat.Prog_name = strrchr(*argv,DIR_CHAR)) != nullptr)
