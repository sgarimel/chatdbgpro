   static bstring* newshortstr(bvm *vm, const char *str, size_t len)
   {
       bstring *s;
       int size = vm->strtab.size;
       uint32_t hash = str_hash(str, len);
       bstring **list = vm->strtab.table + (hash & (size - 1));
   
       for (s = *list; s != NULL; s = next(s)) {
