   TEST_CASE("Backtracking test", "[general]")
   {
       parser parser(
          "  START <- PAT1 / PAT2  "
          "  PAT1  <- HELLO ' One' "
          "  PAT2  <- HELLO ' Two' "
          "  HELLO <- 'Hello'      "
       );
   
       size_t count = 0;
       parser["HELLO"] = [&](const SemanticValues& sv) {
           count++;
       };
   
       parser.enable_packrat_parsing();
   
       bool ret = parser.parse("Hello Two");
       REQUIRE(ret == true);
       REQUIRE(count == 1); // Skip second time
   }
   
