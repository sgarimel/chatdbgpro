   231	/*******************************************************************
   232	 * the function be_str2int():
   233	 * >>-+------------+--+-----+----digits----><
   234	 *    '-whitespace-'  +- + -+
   235	 *                    '- - -'
   236	 *******************************************************************/
   237	BERRY_API bint be_str2int(const char *str, const char **endstr)
   238	{
   239	    int c, sign;
   240	    bint sum = 0;
   241	    skip_space(str);
   242	    sign = c = *str++;
   243	    if (c == '+' || c == '-') {
   244	        c = *str++;
   245	    }
   246	    while (is_digit(c)) {
   247	        sum = sum * 10 + c - '0';
   248	        c = *str++;
   249	    }
   250	    if (endstr) {
   251	        *endstr = str - 1;
   252	    }
   253	    return sign == '-' ? -sum : sum;
   254	}
